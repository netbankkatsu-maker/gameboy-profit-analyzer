# Server Configuration
PORT=3000
NODE_ENV=development

# Firebase Configuration (Phase 4)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email

# Mercari Scraper Settings (Phase 3)
MERCARI_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
MERCARI_REQUEST_DELAY=2000

# Image Recognition (Phase 2)
TF_MODEL_URL=local:///model/
MAX_IMAGE_SIZE=50000000

# Logging
LOG_LEVEL=debug

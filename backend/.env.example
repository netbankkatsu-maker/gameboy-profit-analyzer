# ─── Firebase ────────────────────────────────────────────────────────────────
# Firebase サービスアカウントキーの JSON を1行に圧縮して貼り付ける
# 取得場所: Firebase Console > プロジェクトの設定 > サービスアカウント > 新しい秘密鍵を生成
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"..."}

# ─── CORS ────────────────────────────────────────────────────────────────────
# フロントエンドのURL（カンマ区切りで複数指定可）
CORS_ORIGIN=https://your-frontend.vercel.app

# ─── API Key (本番環境での保護用、オプション) ─────────────────────────────────
# API_KEY=your-secret-key

# ─── ローカル開発用（Railwayでは不要）──────────────────────────────────────────
PORT=3000
NODE_ENV=development
